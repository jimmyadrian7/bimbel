<html>
    
    <head>
        {% include "/Report/View/partial/style.twig" %}
        {% include "/Report/View/kwitansi/style.twig" %}
    </head>

    <body class="{{ tagihan.status == 'l' ? '' : 'kwitansi-lunas' }}">
        <div class="container">

            {% if tagihan.status == 'l'  %}
                <div class="kwitansi-stamp">
                    {{ tagihan.status != 'l' ? '' : 'LUNAS' }}
                </div>
            {% endif %}

            {% include "/Report/View/kwitansi/header.twig" %}

            
            <table class="fn-12 kwitansi-table" width="100%">
                <tr>
                    <td class="kwitansi-left" width="80%" style="vertical-align: top;">
                        <table class="left-table">
                            <tr>
                                <td class="border-btm-2">
                                    {% include "/Report/View/kwitansi/program.twig" %}
                                </td>
                            </tr>

                            <tr>
                                <td class="border-btm-2">
                                    {% include "/Report/View/kwitansi/terima.twig" %}
                                </td>
                            </tr>

                            <tr>
                                <td class="border-btm-2">
                                    {% include "/Report/View/kwitansi/nominal.twig" %}
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    {% include "/Report/View/kwitansi/rekening.twig" %}
                                </td>
                            </tr>
                        </table>
                    </td>

                    <td class="kwitansi-right" width="20%" style="vertical-align: top;">
                        {% include "/Report/View/kwitansi/keterangan.twig" %}
                    </td>
                </tr>
            </table>
        </div>

    </body>
</html>
